# ── LLM Provider (pick one — both are FREE) ─────────────────────────────────
#
# Option A: Groq free tier (cloud, no GPU needed, fast)
#   Sign up free at https://console.groq.com — no credit card required
#   Free: 14,400 requests/day, 30 req/min
GROQ_API_KEY=
#
# Option B: Ollama (local, zero cost, no account, no rate limits)
#   Install: https://ollama.com
#   Pull model: ollama pull qwen2.5:7b
#   Leave GROQ_API_KEY empty and Ollama is used automatically.
OLLAMA_BASE_URL=http://localhost:11434/v1
#
# Override which model to use (optional):
#   Groq options:  llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
#   Ollama options: qwen2.5:7b, llama3.2, mistral, phi3
# LLM_MODEL=qwen2.5:7b

# ── Alpaca brokerage ─────────────────────────────────────────────────────────
# Paper trading (safe — no real money)
# Sign up free at https://alpaca.markets
ALPACA_PAPER_KEY=your_paper_key_here
ALPACA_PAPER_SECRET=your_paper_secret_here

# Live trading (real money — leave blank until ready)
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=

# ── Alpha Vantage (optional — for news sentiment) ────────────────────────────
# Free tier: 25 API calls/day — https://www.alphavantage.co/support/#api-key
# Leave blank to skip news (system works fine without it)
ALPHA_VANTAGE_KEY=

# ── App config ───────────────────────────────────────────────────────────────
TRADING_MODE=paper
